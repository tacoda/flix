<!DOCTYPE html>
<html>
  <head>
    <title>Flix</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>

    <header>
      <h1>Flix</h1>
    </header>

    <div class="content">
      <%= yield %>
    </div>

    <footer>
      <p>
        Copyright &copy; <%= Time.now.year %>
        <%= link_to 'Ian Johnson', 'https://tacoda.github.io' %>
      </p>
    </footer>

  </body>
</html>

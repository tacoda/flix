<section class="movie-details">
  <div class="image">
      <%= image_tag @movie.image_file_name %>
  </div>
  <div class="details">
    <h1><%= @movie.title %></h1>
    <h2>
      <%= year_of(@movie) %> &bull; <%= @movie.rating %>
    </h2>
    <div class="reviews">
      <%= render "shared/stars", percent: @movie.average_stars_as_percent %>
      <%= link_to pluralize(@movie.reviews.size, "review"),
            movie_reviews_path(@movie) %>
    </div>
    <p>
      <%= @movie.description %>
    </p>
    <table>
      <tr>
        <th>Director:</th>
        <td><%=@movie.director %></td>
      </tr>
      <tr>
        <th>Duration:</th>
        <td><%=@movie.duration %></td>
      </tr>
      <tr>
        <th>Total Gross:</th>
        <td><%= total_gross(@movie) %></td>
      </tr>
    </table>

    <%#= link_to "Write Review", new_movie_review_path(@movie),
              class: "review" %>

    <h3>Write A Review for <%= link_to @movie.title, @movie %></h3>

    <%= render 'reviews/form', movie: @movie, review: @review %>
  </div>
</section>

<section class="admin">
  <%= link_to "Edit", edit_movie_path(@movie), class: "button" %>
  <%= link_to "Delete", @movie, class: "button", method: :delete, data: { confirm: "Are you sure?" } %>
</section>
